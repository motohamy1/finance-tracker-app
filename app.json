{
  "expo": {
    "name": "finance-tracker",
    "slug": "finance-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/appicon.png",
    "scheme": [
      "finance-tracker",
      "com.googleusercontent.apps.317497946553-fls1h4ds0g2188l4tl86iv017nj3i6fb"
    ],
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/appicon.png"
    },
    "android": {
      "package": "com.motohamy.financetracker",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/appicon.png",
        "backgroundImage": "./assets/images/appicon.png",
        "monochromeImage": "./assets/images/appicon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/appicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/appicon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "Finance Tracker needs access to your photos to import trading screenshots.",
          "cameraPermission": "Finance Tracker needs camera access to capture trading screenshots."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "10c18ffa-af35-4866-9551-b527ebd7996a"
      }
    }
  }
}
